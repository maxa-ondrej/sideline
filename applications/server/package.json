{
  "name": "@sideline/server",
  "private": true,
  "version": "0.15.4",
  "type": "module",
  "license": "MIT",
  "description": "The server template",
  "repository": {
    "type": "git",
    "url": "<PLACEHOLDER>",
    "directory": "applications/server"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "dev": "tsx watch src/run.ts",
    "preview": "node build/esm/run.js",
    "check": "tsc -b tsconfig.json",
    "test": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "coverage": "vitest --coverage"
  },
  "dependencies": {
    "@effect/platform": "0.96.0",
    "@effect/platform-node": "0.106.0",
    "@effect/rpc": "0.75.0",
    "@effect/sql": "0.51.0",
    "@effect/sql-pg": "0.52.1",
    "@sideline/domain": "workspace:^",
    "@sideline/effect-lib": "workspace:^",
    "@sideline/migrations": "workspace:^",
    "@t3-oss/env-core": "^0.13.8",
    "arctic": "^3.7.0",
    "dfx": "0.127.0",
    "effect": "3.21.0"
  },
  "effect": {
    "generateExports": {
      "include": [
        "**/*.ts"
      ]
    },
    "generateIndex": {
      "include": [
        "**/*.ts"
      ]
    }
  },
  "devDependencies": {
    "testcontainers": "^11.13.0"
  }
}
