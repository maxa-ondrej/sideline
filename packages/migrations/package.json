{
  "private": true,
  "name": "@sideline/migrations",
  "version": "0.12.5",
  "type": "module",
  "license": "MIT",
  "description": "Database migrations for sideline",
  "repository": {
    "type": "git",
    "url": "<PLACEHOLDER>",
    "directory": "packages/migrations"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "scripts": {
    "build": "pnpm build-esm && pnpm build-annotate && pnpm build-cjs && build-utils pack-v2",
    "dev": "tsc-watch -b tsconfig.build.json --onSuccess \"pnpm codegen && pnpm build-annotate && pnpm build-cjs && build-utils pack-v2\"",
    "build-esm": "tsc -b tsconfig.build.json",
    "build-cjs": "babel build/esm --plugins @babel/transform-export-namespace-from --plugins @babel/transform-modules-commonjs --out-dir build/cjs --source-maps",
    "build-annotate": "babel build/esm --plugins annotate-pure-calls --out-dir build/esm --source-maps",
    "check": "tsc -b tsconfig.json",
    "test": "vitest",
    "coverage": "vitest --coverage"
  },
  "dependencies": {
    "@effect/platform": "0.96.0",
    "@effect/platform-node": "0.106.0",
    "@effect/sql": "0.51.0",
    "@effect/sql-pg": "0.52.1",
    "effect": "3.21.0"
  },
  "effect": {
    "generateExports": {
      "include": [
        "**/*.ts"
      ]
    },
    "generateIndex": {
      "include": [
        "**/*.ts"
      ]
    }
  }
}
