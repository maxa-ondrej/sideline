{
  "name": "@sideline/i18n",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Shared translation messages for Sideline",
  "scripts": {
    "build": "paraglide-js compile --project ./project.inlang --outdir ./dist --emit-ts-declarations --strategy localStorage cookie baseLocale"
  },
  "exports": {
    "./messages": "./dist/messages.js",
    "./runtime": "./dist/runtime.js"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.12.0",
    "typescript": "5.7.2"
  }
}
