        "id": "request_rate",
        "panelTypes": "value",
        "query": {
          "builder": { "queryData": [], "queryFormulas": [] },
          "clickhouse_sql": [{ "disabled": false, "name": "A", "query": "" }],
          "promql": [
            {
              "disabled": false,
              "name": "A",
              "query": "sum(rate({\"rpc_requests_total\", \"deployment.environment\"=~\"$environment\"}[5m]))"
