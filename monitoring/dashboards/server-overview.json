{
  "title": "Server Overview",
  "description": "HTTP, cron, and RSVP metrics for the Sideline server",
  "tags": ["server", "http", "cron"],
  "layout": [
    {
      "id": "http_requests_rate",
      "title": "HTTP Requests Rate (per minute)",
      "description": "Rate of HTTP requests by method and status class",
      "panelType": "graph",
      "query": {
        "queryType": "promql",
        "promql": "sum(rate(http_requests_total{service_name=\"sideline-server\"}[1m])) by (method, status_class) * 60"
      }
    },
    {
      "id": "http_error_rate",
      "title": "HTTP 5xx Error Rate",
      "description": "Rate of server error responses",
      "panelType": "graph",
      "query": {
        "queryType": "promql",
        "promql": "sum(rate(http_requests_total{service_name=\"sideline-server\", status_class=\"5xx\"}[1m])) * 60"
      }
    },
    {
      "id": "http_duration_p95",
      "title": "HTTP Duration p95 (ms)",
      "description": "95th percentile HTTP request duration",
      "panelType": "graph",
      "query": {
        "queryType": "promql",
        "promql": "histogram_quantile(0.95, sum(rate(http_request_duration_ms_bucket{service_name=\"sideline-server\"}[5m])) by (le, method))"
      }
    },
    {
      "id": "cron_executions",
      "title": "Cron Executions",
      "description": "Cron job execution counts by name and result",
      "panelType": "graph",
      "query": {
        "queryType": "promql",
        "promql": "sum(rate(cron_executions_total{service_name=\"sideline-server\"}[5m])) by (cron, result) * 300"
      }
    },
    {
      "id": "rsvp_submissions",
      "title": "RSVP Submissions Rate",
      "description": "Rate of RSVP submissions by response type",
      "panelType": "graph",
      "query": {
        "queryType": "promql",
        "promql": "sum(rate(rsvp_submissions_total{service_name=\"sideline-server\"}[5m])) by (response) * 300"
      }
    }
  ]
}
